# ================================================================
# VARIABLES DE ENTORNO — Albert Inmo
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git (ya está en .gitignore).
# ================================================================

# ── Supabase ──────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Solo para scripts de servidor (migraciones, seeds)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Prisma / PostgreSQL ───────────────────────────────────────────
# Supabase → Settings → Database → Connection string
# Para desarrollo local con Docker:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/albert_inmo
#   DIRECT_URL=postgresql://postgres:postgres@localhost:5432/albert_inmo
#
# Para producción (Supabase cloud):
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Cloudinary ────────────────────────────────────────────────────
# cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp ──────────────────────────────────────────────────────
# Número por defecto del agente (sin + ni espacios)
NEXT_PUBLIC_WHATSAPP_PHONE=34600000000

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tudominio.com
